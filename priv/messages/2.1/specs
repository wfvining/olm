                         reservationTime => {ref,'TariffTimeType'},
                         tariffId => {string,#{max_length => 60}},
                         validFrom => datetime},
                   required => [tariffId,currency],
                   additional_properties => false}},
         'DayOfWeekEnumType' =>
             {enum,
                 ['Monday','Tuesday','Wednesday','Thursday','Friday',
                  'Saturday','Sunday']},
         'EvseKindEnumType' => {enum,['AC','DC']},
         'MessageContentType' =>
             {object,
                 #{doc =>
                       #{content =>
                             <<"*(2.1)* Required. Message contents. +\r\nMaximum length supported by Charging Station is given in OCPPCommCtrlr.FieldLength[\"MessageContentType.content\"].\r\n    Maximum length defaults to 1024.">>,
                         language =>
                             <<"Message language identifier. Contains a language code as defined in &lt;&lt;ref-RFC5646,[RFC5646]&gt;&gt;.">>},
                   properties =>
                       #{format => {ref,'MessageFormatEnumType'},
                         customData => {ref,'CustomDataType'},
                         content => {string,#{max_length => 1024}},
                         language => {string,#{max_length => 8}}},
                   required => [format,content],
                   additional_properties => false}},
         'MessageFormatEnumType' =>
             {enum,['ASCII','HTML','URI','UTF8','QRCODE']},
         'PriceType' =>
             {object,
                 #{doc =>
                       #{exclTax =>
                             <<"Price/cost excluding tax. Can be absent if _inclTax_ is present.">>,
                         inclTax =>
                             <<"Price/cost including tax. Can be absent if _exclTax_ is present.">>},
                   properties =>
                       #{customData => {ref,'CustomDataType'},
                         exclTax => {number,#{}},
                         inclTax => {number,#{}},
                         taxRates =>
                             {array,
                                 #{items => {ref,'TaxRateType'},
                                   min_items => 1,max_items => 5}}},
                   required => [],additional_properties => false}},
         'TaxRateType' =>
             {object,
                 #{doc =>
                       #{type =>
                             <<"Type of this tax, e.g.  \"Federal \",  \"State\", for information on receipt.">>,
                         stack =>
                             <<"Stack level for this type of tax. Default value, when absent, is 0. +\r\n_stack_ = 0: tax on net price; +\r\n_stack_ = 1: tax added on top of _stack_ 0; +\r\n_stack_ = 2: tax added on top of _stack_ 1, etc.">>,
                         tax => <<"Tax percentage">>},
                   properties =>
                       #{type => {string,#{max_length => 20}},
                         stack => {integer,#{min => 0}},
                         customData => {ref,'CustomDataType'},
                         tax => {number,#{}}},
                   required => [type,tax],
                   additional_properties => false}},
         'TariffConditionsFixedType' =>
             {object,
                 #{doc =>
                       #{dayOfWeek =>
                             <<"Day(s) of the week this is tariff applies.">>,
                         endTimeOfDay =>
                             <<"End time of day in local time. Same syntax as _startTimeOfDay_. +\r\n    If end time &lt; start time then the period wraps around to the next day. +\r\n    To stop at end of the day use: 00:00.">>,
                         paymentBrand =>
                             <<"For which payment brand this (adhoc) tariff applies. Can be used to add a surcharge for certain payment brands.\r\n    Based on value of _additionalIdToken_ from _idToken.additionalInfo.type_ = \"PaymentBrand\".">>,
                         paymentRecognition =>
                             <<"Type of adhoc payment, e.g. CC, Debit.\r\n    Based on value of _additionalIdToken_ from _idToken.additionalInfo.type_ = \"PaymentRecognition\".">>,
                         startTimeOfDay =>
                             <<"Start time of day in local time. +\r\nFormat as per RFC 3339: time-hour \":\" time-minute  +\r\nMust be in 24h format with leading zeros. Hour/Minute separator: \":\"\r\nRegex: ([0-1][0-9]\\|2[0-3]):[0-5][0-9]">>,
                         validFromDate =>
                             <<"Start date in local time, for example: 2015-12-24.\r\nValid from this day (inclusive). +\r\nFormat as per RFC 3339: full-date  + \r\n\r\nRegex: ([12][0-9]{3})-(0[1-9]\\|1[0-2])-(0[1-9]\\|[12][0-9]\\|3[01])">>,
                         validToDate =>
                             <<"End date in local time, for example: 2015-12-27.\r\n    Valid until this day (exclusive). Same syntax as _validFromDate_.">>},
                   properties =>
                       #{customData => {ref,'CustomDataType'},
                         dayOfWeek =>
                             {array,
                                 #{items => {ref,'DayOfWeekEnumType'},
                                   min_items => 1,max_items => 7}},
                         endTimeOfDay => {string,#{}},
                         evseKind => {ref,'EvseKindEnumType'},
                         paymentBrand => {string,#{max_length => 20}},
                         paymentRecognition => {string,#{max_length => 20}},
                         startTimeOfDay => {string,#{}},
                         validFromDate => {string,#{}},
                         validToDate => {string,#{}}},
                   required => [],additional_properties => false}},
         'TariffConditionsType' =>
             {object,
                 #{doc =>
                       #{dayOfWeek =>
                             <<"Day(s) of the week this is tariff applies.">>,
                         endTimeOfDay =>
                             <<"End time of day in local time. Same syntax as _startTimeOfDay_. +\r\n    If end time &lt; start time then the period wraps around to the next day. +\r\n    To stop at end of the day use: 00:00.">>,
                         startTimeOfDay =>
                             <<"Start time of day in local time. +\r\nFormat as per RFC 3339: time-hour \":\" time-minute  +\r\nMust be in 24h format with leading zeros. Hour/Minute separator: \":\"\r\nRegex: ([0-1][0-9]\\|2[0-3]):[0-5][0-9]">>,
                         validFromDate =>
                             <<"Start date in local time, for example: 2015-12-24.\r\nValid from this day (inclusive). +\r\nFormat as per RFC 3339: full-date  + \r\n\r\nRegex: ([12][0-9]{3})-(0[1-9]\\|1[0-2])-(0[1-9]\\|[12][0-9]\\|3[01])">>,
                         validToDate =>
                             <<"End date in local time, for example: 2015-12-27.\r\n    Valid until this day (exclusive). Same syntax as _validFromDate_.">>,
                         maxChargingTime =>
                             <<"Maximum duration in seconds the charging MUST last (exclusive).\r\n      When the duration of a charging is shorter than the defined value, this price is or becomes active.\r\n      After that moment, this price is no longer active.">>,
                         maxCurrent =>
                             <<"Sum of the maximum current (in Amperes) over all phases, for example 20 A.\r\n      When the EV is charging with less than the defined amount of current, this price becomes/is active. If the charging current is or becomes higher, this price is not or no longer valid and becomes inactive.\r\n      This is NOT about the maximum current over the entire transaction.">>,
                         maxEnergy =>
                             <<"Maximum consumed energy in Wh, for example 50000 Wh.\r\n    Valid until this amount of energy (exclusive) being used.">>,
                         maxIdleTime =>
                             <<"Maximum duration in seconds the idle period (i.e. not charging) MUST last (exclusive).\r\n      When the duration of idle time is shorter than the defined value, this price is or becomes active.\r\n      After that moment, this price is no longer active.">>,
                         maxPower =>
                             <<"Maximum power in W, for example 20000 W.\r\n      When the EV is charging with less than the defined amount of power, this price becomes/is active.\r\n      If the charging power is or becomes higher, this price is not or no longer valid and becomes inactive.\r\n      This is NOT about the maximum power over the entire transaction.">>,
                         maxTime =>
                             <<"Maximum duration in seconds the transaction (charging &amp; idle) MUST last (exclusive).\r\n      When the duration of a transaction is shorter than the defined value, this price is or becomes active.\r\n      After that moment, this price is no longer active.">>,
                         minChargingTime =>
                             <<"Minimum duration in seconds the charging MUST last (inclusive).\r\n      When the duration of a charging is longer than the defined value, this price is or becomes active.\r\n      Before that moment, this price is not yet active.">>,
                         minCurrent =>
                             <<"Sum of the minimum current (in Amperes) over all phases, for example 5 A.\r\n    When the EV is charging with more than, or equal to, the defined amount of current, this price is/becomes active. If the charging current is or becomes lower, this price is not or no longer valid and becomes inactive. +\r\n    This is NOT about the minimum current over the entire transaction.">>,
                         minEnergy =>
