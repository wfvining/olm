                   properties =>
                       #{description =>
                             {array,
                                 #{items => {ref,'MessageContentType'},
                                   min_items => 1,max_items => 10}},
                         currency => {string,#{max_length => 3}},
                         customData => {ref,'CustomDataType'},
                         chargingTime => {ref,'TariffTimeType'},
                         energy => {ref,'TariffEnergyType'},
                         fixedFee => {ref,'TariffFixedType'},
                         idleTime => {ref,'TariffTimeType'},
                         maxCost => {ref,'PriceType'},
                         minCost => {ref,'PriceType'},
