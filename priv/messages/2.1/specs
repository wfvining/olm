                           #{limit => {number,#{}},
                             customData => {ref,'CustomDataType'},
                             dischargeLimit => {number,#{max => 0.0}},
                             dischargeLimit_L2 => {number,#{max => 0.0}},
                             dischargeLimit_L3 => {number,#{max => 0.0}},
                             limit_L2 => {number,#{}},
                             limit_L3 => {number,#{}},
                             setpoint => {number,#{}},
                             setpointReactive => {number,#{}},
                             setpointReactive_L2 => {number,#{}},
                             setpointReactive_L3 => {number,#{}},
                             setpoint_L2 => {number,#{}},
                             setpoint_L3 => {number,#{}}},
                       required => [],additional_properties => false}}},
